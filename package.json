{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "htmlhint": "^1.7.1",
    "http-server": "^14.1.1",
    "linkinator": "^6.3.0",
    "pa11y-ci": "^3.1.0",
    "rimraf": "^6.0.1",
    "start-server-and-test": "^2.1.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^36.0.1",
    "wait-on": "^9.0.1"
  },
  "scripts": {
    "lint:html": "htmlhint \"src/*.html\" \"src/**/*.html\"",
    "lint:css": "stylelint \"src/*.css\" \"src/**/*.css\" --allow-empty-input",
    "lint:js": "eslint \"src/*.js\" \"src/**/*.js\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "test:a11y": "pa11y-ci",
    "build:posix": "rm -rf dist && mkdir dist && cp -r src/* dist/",
    "build:win": "rimraf dist && mkdir dist && xcopy src dist /E /I /Y >NUL",
    "build": "npm run build:posix || npm run build:win"
  }
}
