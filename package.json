{
  "name": "portfolio",
  "private": true,
  "devDependencies": {
    "eslint": "^9.11.0",
    "htmlhint": "^1.1.4",
    "linkinator": "^6.1.2",
    "pa11y-ci": "^3.1.0",
    "stylelint": "^16.8.1",
    "stylelint-config-standard": "^36.0.0"
  },
  "scripts": {
    "lint:html": "htmlhint 'src/**/*.html'",
    "lint:css": "stylelint 'src/**/*.css'",
    "lint:js": "eslint 'src/**/*.js' --max-warnings=0",
    "test:links": "linkinator file:src/index.html --recurse --silent",
    "test:a11y": "pa11y-ci",
    "test": "npm run lint:html && npm run lint:css && npm run lint:js && npm run test:links && npm run test:a11y",
    "build": "rm -rf dist && mkdir dist && cp -r src/* dist/"
  }
}
